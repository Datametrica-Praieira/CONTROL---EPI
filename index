// ── EXPORT CSV ───────────────────────────────────────
function exportCSV(type) {
  let rows,file;
  if (type==='epis') {
    rows=[['Código','Nome','Categoria','CA','Fabricante','Quantidade','Mínimo','Local']];
    state.epis.forEach(e=>rows.push([e.codigo,e.nome,e.categoria,e.ca,e.fabricante,e.quantidade,e.minimo,e.local]));
    file='EPIs_Datametrica.csv';
  } else if (type==='cas') {
    rows=[['Nº CA','Fabricante','CNPJ','Emissão','Validade','Tipo']];
    state.cas.forEach(c=>rows.push([c.numero,c.fabricante,c.cnpj,c.emissao,c.validade,c.tipo]));
    file='CAs_Datametrica.csv';
  } else if (type==='tst') {
    rows=[['Matrícula','Nome','CREA','Telefone','Email','Sites','Status','Cadastro']];
    state.tst.forEach(t=>rows.push([t.matricula,t.nome,t.crea,t.telefone,t.email,t.sites,t.status,t.cadastro]));
    file='Tecnicos_Datametrica.csv';
  } else {
    rows=[['Data','Tipo','EPI','Código','Qtd','Colaborador','Matrícula','Setor','Obs','Técnica','Site']];
    state.hist.forEach(h=>rows.push([h.data,h.tipo,h.epiNome,h.epiCod,h.quantidade,h.colaborador,h.matricula,h.setor,h.obs,h.tecnica,h.site]));
    file='Historico_Datametrica.csv';
  }
  const csv=rows.map(r=>r.map(v=>`"${String(v||'').replace(/"/g,'""')}"`).join(',')).join('\n');
  const a=document.createElement('a');
  a.href='data:text/csv;charset=utf-8,\uFEFF'+encodeURIComponent(csv);
  a.download=file; a.click();
  showToast(`Exportado: ${file}`);
}

// ── GOOGLE SHEETS PUSH ───────────────────────────────
async function pushSheets(sheet,action,data,id) {
  if (!SCRIPT_URL) return;
  try {
    const p={action,sheet};
    if(data) p.data=JSON.stringify(data);
    if(id)   p.id=id;
    await fetch(SCRIPT_URL+'?'+new URLSearchParams(p));
  } catch(_){}
}

