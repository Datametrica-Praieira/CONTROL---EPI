<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Datamétrica — Controle de EPI</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;500;600;700;800;900&family=Nunito+Sans:wght@300;400;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --red:       #D94032;
  --red-dark:  #B8312A;
  --red-light: #E85A4F;
  --red-pale:  #FDECEA;
  --gray-900:  #1A1A1A;
  --gray-800:  #2D2D2D;
  --gray-700:  #444444;
  --gray-500:  #888888;
  --gray-300:  #CCCCCC;
  --gray-100:  #F4F4F4;
  --gray-50:   #FAFAFA;
  --white:     #FFFFFF;
  --green:     #2ECC71;
  --orange:    #F39C12;
  --shadow:    0 4px 24px rgba(0,0,0,.10);
  --shadow-lg: 0 12px 48px rgba(0,0,0,.16);
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { font-size:16px; }
body {
  font-family: 'Nunito Sans', sans-serif;
  background: var(--gray-100);
  min-height: 100vh;
  color: var(--gray-900);
}

/* ─────────────────────────── SCREENS ─────────────────────────── */
.screen { display:none; min-height:100vh; }
.screen.active { display:flex; }

/* ═══════════════════════════════════════════════════════════════
   SCREEN 1 — SELEÇÃO DE SITE
═══════════════════════════════════════════════════════════════ */
#screen-site {
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32px 16px;
  background: linear-gradient(160deg, #f0f0f0 0%, #e8e8e8 100%);
  position: relative;
  overflow: hidden;
}
#screen-site::before {
  content:'';
  position:absolute; top:-120px; right:-80px;
  width:500px; height:500px; border-radius:50%;
  background: radial-gradient(circle, rgba(217,64,50,.08) 0%, transparent 70%);
  pointer-events:none;
}
#screen-site::after {
  content:'';
  position:absolute; bottom:-100px; left:-60px;
  width:400px; height:400px; border-radius:50%;
  background: radial-gradient(circle, rgba(217,64,50,.06) 0%, transparent 70%);
  pointer-events:none;
}

.site-card {
  background: var(--white);
  border-radius: 20px;
  box-shadow: var(--shadow-lg);
  width: 100%; max-width: 540px;
  overflow: hidden;
  animation: cardIn .5s cubic-bezier(.34,1.56,.64,1);
  position: relative; z-index: 1;
}
@keyframes cardIn {
  from { opacity:0; transform:translateY(32px) scale(.97); }
  to   { opacity:1; transform:translateY(0) scale(1); }
}

.card-header {
  background: linear-gradient(135deg, var(--red) 0%, var(--red-light) 100%);
  padding: 36px 32px 28px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.card-header::before {
  content:'';
  position:absolute; top:-40px; right:-40px;
  width:160px; height:160px; border-radius:50%;
  background: rgba(255,255,255,.08);
}
.card-header::after {
  content:'';
  position:absolute; bottom:-30px; left:-30px;
  width:120px; height:120px; border-radius:50%;
  background: rgba(255,255,255,.06);
}

.logo-box {
  display: inline-flex;
  background: var(--white);
  border-radius: 16px;
  padding: 10px 14px;
  margin-bottom: 16px;
  box-shadow: 0 4px 16px rgba(0,0,0,.15);
  gap: 4px;
  align-items: center;
}
.logo-dtm {
  font-family: 'Nunito', sans-serif;
  font-weight: 900; font-size: 26px; letter-spacing: -1px;
  color: var(--red);
  line-height: 1;
}
.logo-dots {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 3px; margin-left: 4px; padding-bottom: 2px;
}
.logo-dots span {
  width: 9px; height: 9px; border-radius: 2px;
  display: block;
}
.dot-dark { background: var(--gray-800); }
.dot-red  { background: var(--red); }
.dot-gray { background: var(--gray-400,#aaa); }

.card-header h1 {
  color: var(--white); font-family: 'Nunito', sans-serif;
  font-size: 20px; font-weight: 800; letter-spacing: -.2px;
  position: relative; z-index:1;
}
.card-header p {
  color: rgba(255,255,255,.75); font-size: 13px; margin-top: 4px;
  position: relative; z-index:1;
}
.header-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(255,255,255,.15); border-radius: 20px;
  padding: 4px 12px; margin-top: 10px; font-size: 12px; color: rgba(255,255,255,.9);
  position: relative; z-index:1;
}
.header-badge::before { content:''; width:7px; height:7px; border-radius:50%; background: #2ECC71; box-shadow:0 0 6px #2ECC71; }

.card-body { padding: 32px; }
.card-body h2 {
  font-family: 'Nunito', sans-serif;
  font-size: 18px; font-weight: 800; color: var(--red);
  text-align: center; margin-bottom: 6px;
}
.card-body .subtitle {
  text-align: center; font-size: 13px; color: var(--gray-500);
  margin-bottom: 24px;
}

.site-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 12px; margin-bottom: 20px;
}
.site-option {
  border: 2px solid var(--gray-300);
  border-radius: 14px;
  padding: 16px 12px;
  cursor: pointer;
  text-align: center;
  transition: .2s ease;
  background: var(--gray-50);
  position: relative; overflow: hidden;
}
.site-option:hover {
  border-color: var(--red);
  background: var(--red-pale);
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(217,64,50,.15);
}
.site-option.selected {
  border-color: var(--red);
  background: var(--red-pale);
  box-shadow: 0 0 0 3px rgba(217,64,50,.15);
}
.site-option .site-icon { font-size: 28px; display: block; margin-bottom: 8px; }
.site-option .site-name {
  font-weight: 700; font-size: 13px; color: var(--gray-800);
  display: block;
}
.site-option .site-loc {
  font-size: 11px; color: var(--gray-500); margin-top: 2px;
  display: block;
}
.site-option .check-mark {
  position: absolute; top: 8px; right: 8px;
  width: 20px; height: 20px; border-radius: 50%;
  background: var(--red); color: white;
  font-size: 11px; display: none;
  align-items: center; justify-content: center;
  font-weight: 700;
}
.site-option.selected .check-mark { display: flex; }

.or-divider {
  text-align: center; font-size: 12px; color: var(--gray-400,#bbb);
  margin: 16px 0; position: relative;
}
.or-divider::before, .or-divider::after {
  content:''; position:absolute; top:50%;
  width: calc(50% - 20px); height: 1px; background: var(--gray-300);
}
.or-divider::before { left:0; }
.or-divider::after  { right:0; }

.inp-group { margin-bottom: 16px; }
.inp-group label {
  display: block; font-size: 11px; font-weight: 700;
  color: var(--gray-700); letter-spacing: 1px;
  text-transform: uppercase; margin-bottom: 6px;
}
.inp-group input, .inp-group select {
  width: 100%; padding: 12px 16px;
  border: 1.5px solid var(--gray-300); border-radius: 10px;
  font-family: 'Nunito Sans', sans-serif; font-size: 14px;
  color: var(--gray-900); background: var(--white); outline: none;
  transition: .2s;
}
.inp-group input:focus, .inp-group select:focus {
  border-color: var(--red);
  box-shadow: 0 0 0 3px rgba(217,64,50,.10);
}
.inp-group select option { background: white; }

.btn-main {
  width: 100%; padding: 14px;
  background: linear-gradient(135deg, var(--red) 0%, var(--red-light) 100%);
  border: none; border-radius: 12px; cursor: pointer;
  font-family: 'Nunito', sans-serif; font-weight: 800;
  font-size: 15px; color: var(--white); letter-spacing: .3px;
  transition: .2s; box-shadow: 0 4px 16px rgba(217,64,50,.35);
}
.btn-main:hover {
  filter: brightness(1.07); transform: translateY(-1px);
  box-shadow: 0 8px 24px rgba(217,64,50,.4);
}
.btn-main:active { transform: translateY(0); }
.btn-main:disabled { opacity:.5; cursor:not-allowed; transform:none; }

/* ═══════════════════════════════════════════════════════════════
   SCREEN 2 — LOGIN
═══════════════════════════════════════════════════════════════ */
#screen-login {
  flex-direction: column;
  align-items: center; justify-content: center;
  padding: 32px 16px;
  background: linear-gradient(160deg, #f0f0f0 0%, #e8e8e8 100%);
}

.breadcrumb-site {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--white); border-radius: 10px;
  padding: 8px 16px; margin-bottom: 20px;
  box-shadow: var(--shadow);
  font-size: 13px; color: var(--gray-700);
  animation: cardIn .4s ease;
}
.breadcrumb-site .bc-icon { font-size: 16px; }
.breadcrumb-site strong { color: var(--red); font-weight: 700; }
.breadcrumb-site .change-btn {
  background: none; border: none; cursor: pointer;
  color: var(--red); font-size: 12px; font-weight: 700;
  padding: 2px 6px; border-radius: 6px; transition:.15s;
}
.breadcrumb-site .change-btn:hover { background: var(--red-pale); }

.lock-icon {
  width: 56px; height: 56px;
  background: linear-gradient(135deg, var(--red), var(--red-light));
  border-radius: 18px;
  display: flex; align-items: center; justify-content: center;
  font-size: 26px; margin: 0 auto 8px;
  box-shadow: 0 8px 24px rgba(217,64,50,.3);
}

.pass-wrap { position: relative; }
.pass-wrap input { padding-right: 44px; }
.pass-toggle {
  position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
  background: none; border: none; cursor: pointer;
  color: var(--gray-500); font-size: 16px;
}

.login-error {
  background: var(--red-pale); border: 1px solid rgba(217,64,50,.2);
  border-radius: 8px; padding: 10px 14px;
  font-size: 13px; color: var(--red); margin-bottom: 16px; display: none;
}
.login-error.show { display: block; }

/* ═══════════════════════════════════════════════════════════════
   SCREEN 3 — DASHBOARD
═══════════════════════════════════════════════════════════════ */
#screen-dashboard {
  flex-direction: column;
  background: var(--gray-100);
}

/* TOP NAV */
.topnav {
  background: var(--white);
  border-bottom: 1px solid var(--gray-300);
  padding: 0 24px;
  display: flex; align-items: center;
  height: 60px; gap: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,.06);
  position: sticky; top: 0; z-index: 100;
}
.nav-logo { display:flex; align-items:center; gap:8px; }
.nav-logo .dtm-badge {
  background: linear-gradient(135deg,var(--red),var(--red-light));
  color: white; font-family:'Nunito',sans-serif;
  font-weight:900; font-size:15px; padding:4px 10px;
  border-radius:8px; letter-spacing:-.5px;
}
.nav-logo .app-name {
  font-weight: 700; font-size: 14px; color: var(--gray-800);
}
.nav-site-pill {
  background: var(--red-pale);
  border: 1px solid rgba(217,64,50,.2);
  border-radius: 20px; padding: 4px 12px;
  font-size: 12px; font-weight: 600; color: var(--red);
  display: flex; align-items: center; gap: 6px;
}
.nav-right { margin-left: auto; display:flex; align-items:center; gap:12px; }
.user-pill {
  display: flex; align-items: center; gap: 8px;
  background: var(--gray-100); border-radius: 20px;
  padding: 6px 14px 6px 6px;
}
.user-avatar {
  width: 28px; height: 28px; border-radius: 50%;
  background: linear-gradient(135deg,var(--red),var(--red-light));
  display:flex; align-items:center; justify-content:center;
  color:white; font-size:12px; font-weight:700;
}
.user-name { font-size:13px; font-weight:600; color:var(--gray-800); }
.btn-logout {
  background: none; border: 1.5px solid var(--gray-300);
  border-radius: 8px; padding: 6px 12px; cursor:pointer;
  font-size: 12px; font-weight: 700; color: var(--gray-600,#666);
  transition:.15s;
}
.btn-logout:hover { border-color:var(--red); color:var(--red); background:var(--red-pale); }

/* TAB BAR */
.tab-bar {
  background: var(--white);
  border-bottom: 1px solid var(--gray-300);
  padding: 0 24px;
  display: flex; gap: 0;
}
.tab-item {
  background: none; border: none; cursor: pointer;
  font-family: 'Nunito Sans',sans-serif;
  font-size: 13px; font-weight: 700;
  color: var(--gray-500); padding: 14px 18px;
  border-bottom: 2.5px solid transparent;
  transition: .15s; display: flex; align-items: center; gap: 6px;
  white-space: nowrap;
}
.tab-item:hover { color: var(--red); background: var(--red-pale); }
.tab-item.active { color: var(--red); border-bottom-color: var(--red); }

/* MAIN CONTENT */
.main-content { flex: 1; padding: 24px; overflow-y: auto; }
.tab-panel { display:none; }
.tab-panel.active { display:block; animation: fadeIn .2s ease; }
@keyframes fadeIn { from{opacity:0;transform:translateY(4px)} to{opacity:1;transform:translateY(0)} }

/* PAGE HEADER */
.page-head {
  display: flex; align-items: center; gap: 16px;
  margin-bottom: 20px;
}
.page-head h2 {
  font-family: 'Nunito',sans-serif;
  font-size: 22px; font-weight: 800; color: var(--gray-900);
}
.page-head .badge {
  background: var(--red-pale); color: var(--red);
  border: 1px solid rgba(217,64,50,.2);
  border-radius: 20px; padding: 3px 12px;
  font-size: 11px; font-weight: 700; letter-spacing: .5px;
}
.ml { margin-left: auto; }

/* STAT CARDS */
.stat-row {
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: 16px; margin-bottom: 24px;
}
.stat-box {
  background: var(--white); border-radius: 16px;
  padding: 20px; box-shadow: var(--shadow);
  display: flex; flex-direction: column; gap: 6px;
  border-left: 4px solid transparent;
  transition: .2s;
}
.stat-box:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
.stat-box.red-l  { border-left-color: var(--red); }
.stat-box.green-l{ border-left-color: var(--green); }
.stat-box.orange-l{ border-left-color: var(--orange); }
.stat-box.gray-l { border-left-color: var(--gray-500); }
.stat-label { font-size: 11px; font-weight: 700; color: var(--gray-500); letter-spacing: .8px; text-transform: uppercase; }
.stat-num {
  font-family: 'Nunito',sans-serif;
  font-size: 34px; font-weight: 900; line-height: 1; color: var(--gray-900);
}
.stat-num.red  { color: var(--red); }
.stat-num.green{ color: var(--green); }
.stat-num.ora  { color: var(--orange); }
.stat-sub { font-size: 12px; color: var(--gray-500); }

/* SECTION */
.section-card {
  background: var(--white); border-radius: 16px;
  box-shadow: var(--shadow); overflow: hidden; margin-bottom: 20px;
}
.sc-head {
  display: flex; align-items: center;
  padding: 16px 20px; border-bottom: 1px solid var(--gray-100);
  gap: 10px;
}
.sc-head h3 {
  font-family: 'Nunito',sans-serif;
  font-size: 15px; font-weight: 800; color: var(--gray-900);
}
.sc-head .sc-ml { margin-left:auto; display:flex; gap:8px; }
.sc-body { padding: 20px; }

/* TABLE */
table { width:100%; border-collapse:collapse; }
thead th {
  padding: 10px 14px; text-align:left;
  font-size: 11px; font-weight: 700; color: var(--gray-500);
  letter-spacing: .8px; text-transform: uppercase;
  background: var(--gray-50);
  border-bottom: 1px solid var(--gray-200,#e5e5e5);
}
tbody tr { border-bottom: 1px solid var(--gray-100); transition:.15s; }
tbody tr:last-child { border-bottom:none; }
tbody tr:hover { background: var(--gray-50); }
td { padding: 12px 14px; font-size: 13px; }

/* STATUS BADGES */
.badge-s {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 3px 10px; border-radius: 20px;
  font-size: 11px; font-weight: 700;
}
.badge-s::before { content:''; width:5px; height:5px; border-radius:50%; }
.bs-ok  { background:#e8faf2; color:#1a9e52; }
.bs-ok::before { background:#2ECC71; }
.bs-warn{ background:#fff8e8; color:#b8860b; }
.bs-warn::before { background:var(--orange); }
.bs-crit{ background:var(--red-pale); color:var(--red); }
.bs-crit::before { background:var(--red); }

/* TIPO MOVIMENTO */
.mov-type {
  display:inline-flex; align-items:center; gap:5px;
  padding:4px 10px; border-radius:8px;
  font-size:11px; font-weight:700;
}
.mt-saida  { background:var(--red-pale); color:var(--red); }
.mt-entrada{ background:#e8faf2; color:#1a9e52; }

/* BUTTONS */
.btn-red {
  background: var(--red); color: var(--white);
  border: none; border-radius: 10px; cursor: pointer;
  font-family:'Nunito Sans',sans-serif; font-weight:700;
  font-size: 13px; padding: 9px 18px;
  transition:.2s; display:inline-flex; align-items:center; gap:6px;
  box-shadow: 0 3px 10px rgba(217,64,50,.3);
}
.btn-red:hover { filter:brightness(1.08); transform:translateY(-1px); }
.btn-outline {
  background: none; color: var(--gray-700);
  border: 1.5px solid var(--gray-300); border-radius: 10px; cursor: pointer;
  font-family:'Nunito Sans',sans-serif; font-weight:600;
  font-size: 13px; padding: 8px 16px; transition:.2s;
  display:inline-flex; align-items:center; gap:6px;
}
.btn-outline:hover { border-color:var(--red); color:var(--red); background:var(--red-pale); }
.btn-sm { padding:5px 10px; font-size:12px; }

/* SEARCH */
.search-bar {
  display:flex; align-items:center; gap:8px;
  background:var(--gray-50); border:1.5px solid var(--gray-300);
  border-radius:10px; padding:8px 12px; max-width:280px;
}
.search-bar input {
  background:none; border:none; outline:none;
  font-size:13px; color:var(--gray-900);
  font-family:'Nunito Sans',sans-serif; width:100%;
}
.search-bar input::placeholder { color:var(--gray-400,#bbb); }

/* MODAL */
.modal-bg {
  display:none; position:fixed; inset:0; z-index:200;
  background:rgba(0,0,0,.45); backdrop-filter:blur(3px);
  align-items:center; justify-content:center; padding:16px;
}
.modal-bg.open { display:flex; }
.modal-box {
  background: var(--white); border-radius: 20px;
  width:100%; max-width: 560px; max-height:90vh; overflow-y:auto;
  box-shadow: 0 24px 80px rgba(0,0,0,.2);
  animation: cardIn .25s cubic-bezier(.34,1.4,.64,1);
}
.modal-top {
  background: linear-gradient(135deg,var(--red),var(--red-light));
  padding: 20px 24px; border-radius: 20px 20px 0 0;
  display:flex; align-items:center; justify-content:space-between;
}
.modal-top h3 { color:white; font-family:'Nunito',sans-serif; font-size:17px; font-weight:800; }
.modal-close {
  background:rgba(255,255,255,.2); border:none; cursor:pointer;
  color:white; font-size:18px; width:32px; height:32px; border-radius:50%;
  display:flex; align-items:center; justify-content:center; transition:.15s;
}
.modal-close:hover { background:rgba(255,255,255,.35); }
.modal-body { padding:24px; }
.modal-footer { padding:16px 24px; border-top:1px solid var(--gray-100); display:flex; gap:10px; justify-content:flex-end; }

/* FORM GRID */
.fgrid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
.fg1 { grid-column:1/-1; }
.fgroup { display:flex; flex-direction:column; gap:6px; }
.fgroup label { font-size:11px; font-weight:700; color:var(--gray-600,#555); letter-spacing:.8px; text-transform:uppercase; }
.fgroup input, .fgroup select, .fgroup textarea {
  padding:11px 14px; border:1.5px solid var(--gray-300); border-radius:10px;
  font-family:'Nunito Sans',sans-serif; font-size:13px; color:var(--gray-900);
  background:var(--white); outline:none; transition:.2s;
}
.fgroup input:focus, .fgroup select:focus, .fgroup textarea:focus {
  border-color:var(--red); box-shadow:0 0 0 3px rgba(217,64,50,.1);
}
.fgroup textarea { resize:vertical; min-height:72px; }
.required { color:var(--red); }

/* MOVIMENTAÇÃO — BOTÕES DE AÇÃO */
.mov-action-row {
  display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
  margin-bottom: 24px;
}
.mov-action-btn {
  border: none; border-radius: 20px; cursor: pointer;
  padding: 28px 24px; text-align: left;
  transition: .25s cubic-bezier(.34,1.4,.64,1);
  position: relative; overflow: hidden;
  display: flex; flex-direction: column; gap: 10px;
}
.mov-action-btn::before {
  content:''; position:absolute; top:-30px; right:-30px;
  width:120px; height:120px; border-radius:50%;
  opacity:.12; transition:.3s;
}
.mov-action-btn:hover { transform:translateY(-4px); }
.mov-action-btn:hover::before { transform:scale(1.3); opacity:.2; }
.mab-saida {
  background: linear-gradient(135deg, var(--red) 0%, var(--red-light) 100%);
  box-shadow: 0 8px 28px rgba(217,64,50,.35);
  color: white;
}
.mab-saida::before { background: white; }
.mab-entrada {
  background: linear-gradient(135deg, #1eaa57 0%, #2ECC71 100%);
  box-shadow: 0 8px 28px rgba(46,204,113,.35);
  color: white;
}
.mab-entrada::before { background: white; }
.mab-icon { font-size: 36px; line-height:1; }
.mab-label { font-family:'Nunito',sans-serif; font-weight:900; font-size: 20px; letter-spacing:-.3px; }
.mab-desc { font-size: 13px; opacity:.85; font-weight:500; }
.mab-arrow { position:absolute; right:20px; bottom:20px; font-size:28px; opacity:.4; transition:.2s; }
.mov-action-btn:hover .mab-arrow { opacity:.8; right:14px; }
.mov-container { display:none; overflow:hidden; animation: expandDown .3s cubic-bezier(.34,1.2,.64,1); }
.mov-container.open { display:block; }
@keyframes expandDown { from{opacity:0;transform:translateY(-12px)} to{opacity:1;transform:translateY(0)} }
.mov-form-card { background:var(--white); border-radius:20px; box-shadow:var(--shadow-lg); overflow:hidden; margin-bottom:8px; }
.mov-form-header { padding:16px 24px; display:flex; align-items:center; justify-content:space-between; }
.mfh-saida  { background:linear-gradient(90deg,var(--red-pale),white); border-bottom:2px solid rgba(217,64,50,.12); }
.mfh-entrada{ background:linear-gradient(90deg,#e8faf2,white); border-bottom:2px solid rgba(46,204,113,.15); }
.mov-form-title { font-family:'Nunito',sans-serif; font-weight:800; font-size:16px; display:flex; align-items:center; gap:8px; }
.mft-saida  { color:var(--red); }
.mft-entrada{ color:#1eaa57; }
.btn-close-form { background:var(--gray-100); border:none; cursor:pointer; border-radius:50%; width:32px; height:32px; font-size:18px; color:var(--gray-500); display:flex; align-items:center; justify-content:center; transition:.15s; }
.btn-close-form:hover { background:var(--gray-300); color:var(--gray-900); }
.mov-form-body { padding:24px; }
.mov-form-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.mov-fg1 { grid-column:1/-1; }
.func-tag { display:inline-flex; align-items:center; gap:4px; background:var(--red-pale); color:var(--red); border:1px solid rgba(217,64,50,.2); border-radius:20px; padding:4px 12px; font-size:12px; font-weight:700; cursor:pointer; transition:.15s; white-space:nowrap; }
.func-tag:hover { background:var(--red); color:white; }
.func-tags-row { display:flex; flex-wrap:wrap; gap:8px; margin-top:8px; }
.epi-sugestao-box { background:var(--gray-50); border:1.5px dashed var(--gray-300); border-radius:12px; padding:12px 16px; margin-top:8px; display:none; }
.epi-sugestao-box.show { display:block; }
.epi-sug-title { font-size:11px; font-weight:700; color:var(--gray-500); text-transform:uppercase; letter-spacing:.8px; margin-bottom:8px; }
.epi-sug-item { display:flex; align-items:center; gap:8px; padding:6px 0; border-bottom:1px solid var(--gray-200,#e5e5e5); font-size:13px; }
.epi-sug-item:last-child { border-bottom:none; }
.btn-registrar { width:100%; padding:14px; border:none; border-radius:12px; cursor:pointer; font-family:'Nunito',sans-serif; font-weight:900; font-size:15px; display:flex; align-items:center; justify-content:center; gap:8px; transition:.2s; margin-top:4px; }
.br-saida  { background:linear-gradient(135deg,var(--red),var(--red-light)); color:white; box-shadow:0 4px 16px rgba(217,64,50,.35); }
.br-saida:hover  { filter:brightness(1.08); transform:translateY(-1px); }
.br-entrada{ background:linear-gradient(135deg,#1eaa57,#2ECC71); color:white; box-shadow:0 4px 16px rgba(46,204,113,.35); }
.br-entrada:hover{ filter:brightness(1.08); transform:translateY(-1px); }

/* EPI CARDS MINI */
.epi-mini-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:12px; }
.epi-mini {
  background:var(--white); border:1.5px solid var(--gray-200,#e5e5e5);
  border-radius:14px; padding:16px; transition:.2s; cursor:pointer;
}
.epi-mini:hover { border-color:var(--red); box-shadow:0 4px 16px rgba(217,64,50,.12); }
.epi-mini-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px; }
.epi-emoji-big { font-size:28px; }
.epi-mini-name { font-weight:700; font-size:13px; margin-bottom:3px; }
.epi-mini-code { font-size:11px; color:var(--gray-500); font-family:'Nunito Sans',monospace; }
.epi-mini-qty {
  font-family:'Nunito',sans-serif; font-weight:900; font-size:28px; line-height:1;
}
.epi-mini-qty.ok   { color:var(--green); }
.epi-mini-qty.warn { color:var(--orange); }
.epi-mini-qty.crit { color:var(--red); }
.qty-track { height:4px; background:var(--gray-200,#e5e5e5); border-radius:2px; margin-top:8px; overflow:hidden; }
.qty-fill { height:100%; border-radius:2px; }
.qf-ok   { background:var(--green); }
.qf-warn { background:var(--orange); }
.qf-crit { background:var(--red); }

/* TOAST */
#toast {
  position:fixed; bottom:24px; right:24px; z-index:999;
  background:var(--white); border-radius:12px;
  box-shadow:0 8px 32px rgba(0,0,0,.15);
  padding:14px 20px; min-width:260px; max-width:340px;
  display:none; align-items:center; gap:12px;
  border-left:4px solid var(--green);
  animation:slideL .3s ease;
}
@keyframes slideL { from{opacity:0;transform:translateX(20px)} to{opacity:1;transform:translateX(0)} }
#toast.show { display:flex; }
#toast.t-ok   { border-left-color:var(--green); }
#toast.t-err  { border-left-color:var(--red); }
#toast.t-warn { border-left-color:var(--orange); }
.toast-icon { font-size:20px; }
.toast-msg  { font-size:13px; font-weight:600; color:var(--gray-800); }

/* CA validade */
.ca-badge { background:rgba(77,124,200,.08); color:#3a6abf; border:1px solid rgba(77,124,200,.2); padding:2px 8px; border-radius:6px; font-size:11px; font-family:'Nunito Sans',monospace; font-weight:600; }

/* EMPTY STATE */
.empty { text-align:center; padding:48px 20px; color:var(--gray-400,#bbb); }
.empty .ei { font-size:40px; margin-bottom:12px; opacity:.5; }
.empty p { font-size:13px; }

/* RESPONSIVE */
@media(max-width:900px) {
  .stat-row { grid-template-columns:1fr 1fr; }
  .move-grid { grid-template-columns:1fr; }
}
@media(max-width:640px) {
  .stat-row { grid-template-columns:1fr 1fr; }
  .fgrid { grid-template-columns:1fr; }
  .fgrid .fg1 { grid-column:1; }
  .site-grid { grid-template-columns:1fr 1fr; }
  .main-content { padding:16px; }
  .tab-item { padding:12px 10px; font-size:12px; }
}
</style>
</head>
<body>

<!-- ══════════════════════════════════════════════════════
     SCREEN 1 — SELEÇÃO DE SITE/PRÉDIO
══════════════════════════════════════════════════════ -->
<div class="screen active" id="screen-site">
  <div class="site-card">
    <div class="card-header">
      <div class="logo-box">
        <span class="logo-dtm">DTM</span>
        <div class="logo-dots">
          <span class="dot-dark"></span><span class="dot-red"></span>
          <span class="dot-red"></span><span class="dot-gray"></span>
        </div>
      </div>
      <h1>DATAMÉTRICA</h1>
      <p>pesquisa e consultoria</p>
      <div class="header-badge">Sistema de Controle de EPI</div>
    </div>
    <div class="card-body">
      <h2>📍 Selecione o Local</h2>
      <p class="subtitle">Escolha o site ou prédio onde você está atuando</p>

      <div class="site-grid" id="site-grid">
        <!-- Populado via JS -->
      </div>

      <button class="btn-main" onclick="goToLogin()" id="btn-site-next" style="margin-top:8px;">
        Continuar →
      </button>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
     SCREEN 2 — LOGIN
══════════════════════════════════════════════════════ -->
<div class="screen" id="screen-login">
  <div style="display:flex;flex-direction:column;align-items:center;width:100%;">
    <div class="breadcrumb-site" id="bc-site">
      <span class="bc-icon">📍</span>
      Site: <strong id="bc-site-name">—</strong>
      <button class="change-btn" onclick="goBack('screen-site')">Alterar</button>
    </div>

    <div class="site-card" style="max-width:440px;">
      <div class="card-header">
        <div class="logo-box">
          <span class="logo-dtm">DTM</span>
          <div class="logo-dots">
            <span class="dot-dark"></span><span class="dot-red"></span>
            <span class="dot-red"></span><span class="dot-gray"></span>
          </div>
        </div>
        <h1>Acesso ao Sistema</h1>
        <p>Controle de EPI — Técnica de Segurança</p>
      </div>
      <div class="card-body">
        <div style="text-align:center;margin-bottom:20px;">
          <div class="lock-icon">🔐</div>
          <p style="font-size:13px;color:var(--gray-500);margin-top:6px;">Área restrita — Somente técnicas autorizadas</p>
        </div>

        <div class="login-error" id="login-error">
          ❌ Matrícula ou senha incorretos. Tente novamente.
        </div>

        <div class="inp-group">
          <label>Matrícula *</label>
          <input type="text" id="login-mat" placeholder="Digite sua matrícula" autocomplete="username">
        </div>
        <div class="inp-group">
          <label>Senha *</label>
          <div class="pass-wrap">
            <input type="password" id="login-pass" placeholder="••••••••" autocomplete="current-password" onkeydown="if(event.key==='Enter')doLogin()">
            <button class="pass-toggle" type="button" onclick="togglePass()" id="pass-eye">👁</button>
          </div>
        </div>
        <button class="btn-main" onclick="doLogin()">🔓 Entrar no Sistema</button>
        <p style="text-align:center;font-size:11px;color:var(--gray-400,#bbb);margin-top:14px;">
          Acesso monitorado · Datamétrica Pesquisa e Consultoria
        </p>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
     SCREEN 3 — DASHBOARD PRINCIPAL
══════════════════════════════════════════════════════ -->
<div class="screen" id="screen-dashboard">
  <!-- TOP NAV -->
  <nav class="topnav">
    <div class="nav-logo">
      <span class="dtm-badge">DTM</span>
      <span class="app-name">Controle de EPI</span>
    </div>
    <div class="nav-site-pill">
      📍 <span id="nav-site-name">—</span>
    </div>
    <div class="nav-right">
      <div class="user-pill">
        <div class="user-avatar" id="nav-avatar">TS</div>
        <span class="user-name" id="nav-user">Técnica</span>
      </div>
      <button class="btn-logout" onclick="doLogout()">Sair</button>
    </div>
  </nav>

  <!-- TAB BAR -->
  <div class="tab-bar">
    <button class="tab-item active" onclick="goTab('tab-dashboard',this)">📊 Dashboard</button>
    <button class="tab-item" onclick="goTab('tab-estoque',this)">🦺 Estoque</button>
    <button class="tab-item" onclick="goTab('tab-ca',this)">📄 C.A.</button>
    <button class="tab-item" onclick="goTab('tab-movimentacao',this)">↕ Movimentação</button>
    <button class="tab-item" onclick="goTab('tab-historico',this)">📋 Histórico</button>
    <button class="tab-item tab-admin" id="tab-btn-tst" onclick="goTab('tab-tst',this)" style="display:none;">🛡️ Técnicos (TST)</button>
  </div>

  <!-- MAIN -->
  <div class="main-content">

    <!-- ── DASHBOARD ── -->
    <div class="tab-panel active" id="tab-dashboard">
      <div class="page-head">
        <h2>Visão Geral</h2>
        <span class="badge" id="dash-site-badge">—</span>
        <div class="ml">
          <button class="btn-red" onclick="switchTab('tab-estoque')">+ Novo EPI</button>
        </div>
      </div>
      <div class="stat-row">
        <div class="stat-box red-l">
          <span class="stat-label">Total EPIs</span>
          <span class="stat-num red" id="s-total">0</span>
          <span class="stat-sub">cadastrados</span>
        </div>
        <div class="stat-box green-l">
          <span class="stat-label">Estoque OK</span>
          <span class="stat-num green" id="s-ok">0</span>
          <span class="stat-sub">dentro do mínimo</span>
        </div>
        <div class="stat-box orange-l">
          <span class="stat-label">Atenção</span>
          <span class="stat-num ora" id="s-warn">0</span>
          <span class="stat-sub">abaixo do mínimo</span>
        </div>
        <div class="stat-box gray-l">
          <span class="stat-label">Crítico</span>
          <span class="stat-num red" id="s-crit">0</span>
          <span class="stat-sub">estoque zerado</span>
        </div>
      </div>
      <div class="epi-mini-grid" id="dash-cards">
        <div class="empty"><div class="ei">🦺</div><p>Nenhum EPI. Cadastre na aba Estoque.</p></div>
      </div>
    </div>

    <!-- ── ESTOQUE ── -->
    <div class="tab-panel" id="tab-estoque">
      <div class="page-head">
        <h2>Estoque de EPIs</h2>
        <div class="ml" style="display:flex;gap:8px;">
          <button class="btn-outline" onclick="exportCSV('epis')">⬇ CSV</button>
          <button class="btn-red" onclick="openModal('modal-epi')">+ Cadastrar EPI</button>
        </div>
      </div>
      <div class="section-card">
        <div class="sc-head">
          <h3>Todos os EPIs</h3>
          <div class="sc-ml">
            <div class="search-bar">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              <input type="text" id="s-epi" placeholder="Buscar..." oninput="renderEpiTable()">
            </div>
          </div>
        </div>
        <table>
          <thead><tr>
            <th>Código</th><th>EPI / Nomenclatura</th><th>Categoria</th>
            <th>C.A.</th><th>Qtd.</th><th>Mín.</th><th>Status</th><th>Ações</th>
          </tr></thead>
          <tbody id="epi-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- ── C.A. ── -->
    <div class="tab-panel" id="tab-ca">
      <div class="page-head">
        <h2>Certificados de Aprovação</h2>
        <div class="ml" style="display:flex;gap:8px;">
          <button class="btn-outline" onclick="exportCSV('cas')">⬇ CSV</button>
          <button class="btn-red" onclick="openModal('modal-ca')">+ Novo C.A.</button>
        </div>
      </div>
      <div class="section-card">
        <div class="sc-head">
          <h3>C.A. Registrados</h3>
          <div class="sc-ml">
            <div class="search-bar">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              <input type="text" id="s-ca" placeholder="Buscar C.A...." oninput="renderCATable()">
            </div>
          </div>
        </div>
        <table>
          <thead><tr>
            <th>Nº C.A.</th><th>EPI</th><th>Fabricante</th>
            <th>CNPJ</th><th>Validade</th><th>Status</th><th>Ações</th>
          </tr></thead>
          <tbody id="ca-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- ── MOVIMENTAÇÃO ── -->
    <div class="tab-panel" id="tab-movimentacao">
      <div class="page-head">
        <h2>Movimentação de EPI</h2>
        <span class="badge" id="mov-site-label">—</span>
      </div>

      <!-- BOTÕES DE AÇÃO -->
      <div class="mov-action-row">
        <button class="mov-action-btn mab-saida" onclick="toggleContainer('cont-saida','cont-entrada')">
          <span class="mab-icon">📤</span>
          <span class="mab-label">Registrar Saída</span>
          <span class="mab-desc">Entrega de EPI para colaborador</span>
          <span class="mab-arrow">→</span>
        </button>
        <button class="mov-action-btn mab-entrada" onclick="toggleContainer('cont-entrada','cont-saida')">
          <span class="mab-icon">📥</span>
          <span class="mab-label">Registrar Entrada</span>
          <span class="mab-desc">Recebimento de material / fornecedor</span>
          <span class="mab-arrow">→</span>
        </button>
      </div>

      <!-- CONTAINER SAÍDA -->
      <div class="mov-container" id="cont-saida">
        <div class="mov-form-card">
          <div class="mov-form-header mfh-saida">
            <span class="mov-form-title mft-saida">📤 Saída — Entrega de EPI ao Colaborador</span>
            <button class="btn-close-form" onclick="closeContainer('cont-saida')">×</button>
          </div>
          <div class="mov-form-body">
            <div class="mov-form-grid">

              <!-- Função com tags de sugestão -->
              <div class="fgroup mov-fg1">
                <label>Função / Cargo do Colaborador <span class="required">*</span></label>
                <select id="mv-s-funcao" onchange="sugerirEPIs(this.value)">
                  <option value="">Selecione a função</option>
                  <option value="Eletricista">⚡ Eletricista</option>
                  <option value="Soldador">🔥 Soldador</option>
                  <option value="Operador de Altura">🪂 Operador de Altura</option>
                  <option value="Operador de Máquinas">⚙️ Operador de Máquinas</option>
                  <option value="Pedreiro / Servente">🧱 Pedreiro / Servente</option>
                  <option value="Pintor">🖌️ Pintor</option>
                  <option value="Encanador">🔧 Encanador</option>
                  <option value="Vigilante">🛡️ Vigilante</option>
                  <option value="Limpeza / Conservação">🧹 Limpeza / Conservação</option>
                  <option value="Técnico de Segurança">⛑️ Técnico de Segurança</option>
                  <option value="Outro">📋 Outro</option>
                </select>
                <!-- EPIs sugeridos pela função -->
                <div class="epi-sugestao-box" id="epi-sugestao-box">
                  <div class="epi-sug-title">⚡ EPIs recomendados para esta função</div>
                  <div id="epi-sugestao-lista"></div>
                </div>
              </div>

              <div class="fgroup">
                <label>Colaborador — Nome Completo <span class="required">*</span></label>
                <input type="text" id="mv-s-colab" placeholder="Nome de quem está retirando">
              </div>
              <div class="fgroup">
                <label>Matrícula / CPF</label>
                <input type="text" id="mv-s-mat" placeholder="000.000.000-00">
              </div>

              <div class="fgroup">
                <label>EPI <span class="required">*</span></label>
                <select id="mv-s-epi"><option value="">Selecione o EPI</option></select>
              </div>
              <div class="fgroup">
                <label>Quantidade <span class="required">*</span></label>
                <input type="number" id="mv-s-qty" min="1" value="1">
              </div>

              <div class="fgroup mov-fg1">
                <label>Motivo / Observação</label>
                <input type="text" id="mv-s-obs" placeholder="Ex: Substituição por desgaste, primeiro uso...">
              </div>

              <div class="fgroup mov-fg1">
                <button class="btn-registrar br-saida" onclick="registrar('saida')">
                  📤 CONFIRMAR SAÍDA
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- CONTAINER ENTRADA -->
      <div class="mov-container" id="cont-entrada">
        <div class="mov-form-card">
          <div class="mov-form-header mfh-entrada">
            <span class="mov-form-title mft-entrada">📥 Entrada — Recebimento de EPI</span>
            <button class="btn-close-form" onclick="closeContainer('cont-entrada')">×</button>
          </div>
          <div class="mov-form-body">
            <div class="mov-form-grid">
              <div class="fgroup">
                <label>EPI <span class="required">*</span></label>
                <select id="mv-e-epi"><option value="">Selecione o EPI</option></select>
              </div>
              <div class="fgroup">
                <label>Quantidade <span class="required">*</span></label>
                <input type="number" id="mv-e-qty" min="1" value="1">
              </div>
              <div class="fgroup">
                <label>Fornecedor</label>
                <input type="text" id="mv-e-forn" placeholder="Nome do fornecedor">
              </div>
              <div class="fgroup">
                <label>Nota Fiscal / Pedido</label>
                <input type="text" id="mv-e-nf" placeholder="Nº da NF">
              </div>
              <div class="fgroup">
                <label>Validade do Lote</label>
                <input type="date" id="mv-e-val">
              </div>
              <div class="fgroup">
                <label>Observação</label>
                <input type="text" id="mv-e-obs" placeholder="Ex: Lote novo, reposição...">
              </div>
              <div class="fgroup mov-fg1">
                <button class="btn-registrar br-entrada" onclick="registrar('entrada')">
                  📥 CONFIRMAR ENTRADA
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- ── HISTÓRICO ── -->
    <div class="tab-panel" id="tab-historico">
      <div class="page-head">
        <h2>Histórico de Movimentações</h2>
        <div class="ml" style="display:flex;gap:8px;">
          <button class="btn-outline" onclick="exportCSV('hist')">⬇ CSV</button>
        </div>
      </div>
      <div class="section-card">
        <div class="sc-head">
          <h3>Registros</h3>
          <div class="sc-ml" style="display:flex;gap:8px;align-items:center;">
            <select id="f-hist-tipo" style="border:1.5px solid var(--gray-300);border-radius:8px;padding:7px 10px;font-size:12px;background:white;outline:none;" onchange="renderHistTable()">
              <option value="">Todos</option>
              <option value="saida">Saídas</option>
              <option value="entrada">Entradas</option>
            </select>
            <div class="search-bar">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              <input type="text" id="s-hist" placeholder="Buscar..." oninput="renderHistTable()">
            </div>
          </div>
        </div>
        <table>
          <thead><tr>
