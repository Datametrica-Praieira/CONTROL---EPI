// ── TST CRUD ─────────────────────────────────────────
function salvarTST() {
  const mat   = document.getElementById('f-tst-mat').value.trim();
  const senha = document.getElementById('f-tst-senha').value.trim();
  const nome  = document.getElementById('f-tst-nome').value.trim();
  if (!mat || !senha || !nome) { showToast('Matrícula, senha e nome são obrigatórios.','warn'); return; }

  // Verificar duplicata de matrícula
  const editId = document.getElementById('f-tst-id').value;
  const dup = state.tst.find(t => t.matricula === mat && t.id !== editId);
  if (dup) { showToast('Matrícula já cadastrada!','err'); return; }

  const checks = [...document.querySelectorAll('#tst-sites-check input:checked')].map(c => c.value);
  const tst = {
    id:        editId || Date.now().toString(),
    matricula: mat, senha, nome,
    crea:      document.getElementById('f-tst-crea').value,
    telefone:  document.getElementById('f-tst-tel').value,
    email:     document.getElementById('f-tst-email').value,
    sites:     checks.join(', ') || 'Todos',
    status:    document.getElementById('f-tst-status').value,
    cadastro:  editId ? undefined : new Date().toLocaleDateString('pt-BR'),
  };
  if (!tst.cadastro) {
    const ex = state.tst.find(t=>t.id===editId);
    tst.cadastro = ex ? ex.cadastro : new Date().toLocaleDateString('pt-BR');
  }

  // Sincroniza com USERS em memória (para login funcionar)
  const uIdx = USERS.findIndex(u => u.matricula === mat);
  if (uIdx !== -1) { USERS[uIdx].senha = senha; USERS[uIdx].nome = nome; }
  else USERS.push({ matricula:mat, senha, nome, cargo:'Técnica de Segurança' });

  if (editId) { const i=state.tst.findIndex(t=>t.id===editId); if(i!==-1) state.tst[i]=tst; }
  else state.tst.push(tst);

  pushSheets('tst', editId?'update':'insert', tst, editId||undefined);
  save(); renderAll(); closeModal('modal-tst');
  showToast(`Técnico "${nome}" salvo!`);
}

function editTST(id) {
  const t = state.tst.find(x=>x.id===id); if(!t) return;
  document.getElementById('f-tst-id').value     = t.id;
  document.getElementById('f-tst-mat').value    = t.matricula;
  document.getElementById('f-tst-senha').value  = t.senha||'';
  document.getElementById('f-tst-nome').value   = t.nome;
  document.getElementById('f-tst-crea').value   = t.crea||'';
  document.getElementById('f-tst-tel').value    = t.telefone||'';
  document.getElementById('f-tst-email').value  = t.email||'';
  document.getElementById('f-tst-status').value = t.status||'Ativo';
  document.querySelectorAll('#tst-sites-check input').forEach(cb => {
    cb.checked = t.sites && t.sites.includes(cb.value);
  });
  document.getElementById('modal-tst-title').textContent = '✎ Editar Técnico';
  openModal('modal-tst');
}

function delTST(id) {
  const t = state.tst.find(x=>x.id===id); if(!t) return;
  if (!confirm(`Excluir o técnico "${t.nome}"?`)) return;
  state.tst = state.tst.filter(x=>x.id!==id);
  // Remove do USERS em memória
  const uIdx = USERS.findIndex(u => u.matricula === t.matricula);
  if (uIdx !== -1) USERS.splice(uIdx, 1);
  pushSheets('tst','delete',null,id);
  save(); renderAll();
  showToast(`Técnico removido.`,'warn');
}

function toggleTSTStatus(id) {
  const t = state.tst.find(x=>x.id===id); if(!t) return;
  t.status = t.status === 'Ativo' ? 'Inativo' : 'Ativo';
  // Atualiza USERS
  const uIdx = USERS.findIndex(u => u.matricula === t.matricula);
  if (uIdx !== -1) USERS[uIdx].ativo = t.status === 'Ativo';
  pushSheets('tst','update',t,id);
  save(); renderTSTTable();
  showToast(`${t.nome}: ${t.status}`);
}

