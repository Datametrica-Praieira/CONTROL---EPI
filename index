// ── MOVIMENTAÇÃO — CONTAINERS ────────────────────────
function toggleContainer(openId, closeId) {
  const toOpen  = document.getElementById(openId);
  const toClose = document.getElementById(closeId);
  const isOpen  = toOpen.classList.contains('open');
  // fechar o outro
  if (toClose) toClose.classList.remove('open');
  // toggle o clicado
  if (isOpen) { toOpen.classList.remove('open'); }
  else        { toOpen.classList.add('open'); toOpen.scrollIntoView({behavior:'smooth', block:'nearest'}); }
  populateMoveSelects();
  // atualiza badge do site
  const lbl = document.getElementById('mov-site-label');
  if (lbl) lbl.textContent = state.selectedSite?.nome || '—';
}
function closeContainer(id) {
  document.getElementById(id).classList.remove('open');
}

// FUNÇÕES → EPIs sugeridos
const FUNCAO_EPIS = {
  'Eletricista':          ['Capacete de Segurança','Luva Isolante BT','Óculos de Proteção','Botina de Segurança','Cinto de Segurança'],
