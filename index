<script>
// ════════════════════════════════════════════════════════
//  DATAMÉTRICA — EPI CONTROL SYSTEM
// ════════════════════════════════════════════════════════

// ── GOOGLE SHEETS CONFIG ──────────────────────────────
let SCRIPT_URL = localStorage.getItem('https://script.google.com/macros/s/AKfycbxtpmfvJc6pEAVe3EFISnAlT_Vx-4IobSpE76v5vNKwj6NxqI3WMAEEKieq4AriPkXDAw/exec') || '';

// ── USUÁRIOS (adicione/modifique aqui) ────────────────
const USERS = [
  { matricula:'41418', senha:'87953998', nome:'Administrador', cargo:'Admin' },
];

// ── SITES PADRÃO ──────────────────────────────────────
const SITES = [
  { id:'s1', nome:'Praieira', icon:'🏢' },
  { id:'s2', nome:'BJ-1',     icon:'🏢' },
  { id:'s3', nome:'BJ-2',     icon:'🏢' },
  { id:'s4', nome:'Olinda',   icon:'🏢' },
];

// ── ESTADO ────────────────────────────────────────────
let state = {
  selectedSite: null,
  loggedUser:   null,
  epis:      JSON.parse(localStorage.getItem('dtm_epis')  || '[]'),
  cas:       JSON.parse(localStorage.getItem('dtm_cas')   || '[]'),
  hist:      JSON.parse(localStorage.getItem('dtm_hist')  || '[]'),
  tst:       JSON.parse(localStorage.getItem('dtm_tst')   || '[]'),
  accessLog: JSON.parse(localStorage.getItem('dtm_log')   || '[]'),
};

function save() {
  localStorage.setItem('dtm_epis', JSON.stringify(state.epis));
  localStorage.setItem('dtm_cas',  JSON.stringify(state.cas));
  localStorage.setItem('dtm_hist', JSON.stringify(state.hist));
  localStorage.setItem('dtm_tst',  JSON.stringify(state.tst));
  localStorage.setItem('dtm_log',  JSON.stringify(state.accessLog));
}

// ── SCREENS ───────────────────────────────────────────
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
function goBack(to) { showScreen(to); }

// ── SITE SELECTION ────────────────────────────────────
function renderSiteGrid() {
  const grid = document.getElementById('site-grid');
  grid.innerHTML = SITES.map(s => `
    <div class="site-option" id="so-${s.id}" onclick="selectSite('${s.id}')">
      <div class="check-mark">✓</div>
      <span class="site-icon">${s.icon}</span>
      <span class="site-name">${s.nome.split('—')[0].trim()}</span>
      <span class="site-loc">${s.nome.includes('—') ? s.nome.split('—')[1].trim() : ''}</span>
    </div>
  `).join('');
}

function selectSite(id) {
  document.querySelectorAll('.site-option').forEach(e => e.classList.remove('selected'));
  const el = document.getElementById('so-'+id);
  if (el) el.classList.add('selected');
  state.selectedSite = SITES.find(s => s.id === id);
}

function goToLogin() {
  if (!state.selectedSite) { showToast('Selecione um local para continuar.','warn'); return; }
  document.getElementById('bc-site-name').textContent = state.selectedSite.nome;
  showScreen('screen-login');
  setTimeout(() => document.getElementById('login-mat').focus(), 100);
}

// ── LOGIN ─────────────────────────────────────────────
function togglePass() {
  const inp = document.getElementById('login-pass');
  inp.type = inp.type === 'password' ? 'text' : 'password';
}

function doLogin() {
  const mat  = document.getElementById('login-mat').value.trim();
  const pass = document.getElementById('login-pass').value;
  const err  = document.getElementById('login-error');
  const user = USERS.find(u => u.matricula === mat && u.senha === pass);
  if (!user) { err.classList.add('show'); return; }
  err.classList.remove('show');
  state.loggedUser = user;
  // Update nav
  document.getElementById('nav-site-name').textContent = state.selectedSite.nome;
  document.getElementById('nav-user').textContent = user.nome.split(' ')[0];
  document.getElementById('nav-avatar').textContent = user.nome.split(' ').map(w=>w[0]).slice(0,2).join('');
  document.getElementById('dash-site-badge').textContent = state.selectedSite.nome;
  // Mostrar aba TST apenas para admin
  const tstBtn = document.getElementById('tab-btn-tst');
  if (tstBtn) tstBtn.style.display = user.cargo === 'Admin' ? 'flex' : 'none';

  // Registrar acesso no log
  state.accessLog.unshift({
    data: new Date().toLocaleString('pt-BR'),
    matricula: user.matricula,
    nome: user.nome,
    site: state.selectedSite?.nome,
    acao: 'Login'
  });
  save();

  showScreen('screen-dashboard');
  populateMoveSelects();
  renderAll();
  showToast(`Bem-vinda, ${user.nome.split(' ')[0]}! ✅`);
}

function doLogout() {
  if (state.loggedUser) {
    state.accessLog.unshift({
      data: new Date().toLocaleString('pt-BR'),
      matricula: state.loggedUser.matricula,
      nome: state.loggedUser.nome,
      site: state.selectedSite?.nome,
      acao: 'Logout'
    });
    save();
  }
  state.loggedUser = null;
  document.getElementById('login-mat').value = '';
  document.getElementById('login-pass').value = '';
  showScreen('screen-site');
}

// ── TABS ─────────────────────────────────────────────
function goTab(panelId, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-item').forEach(b => b.classList.remove('active'));
  document.getElementById(panelId).classList.add('active');
  if (btn) btn.classList.add('active');
  if (panelId === 'tab-movimentacao') populateMoveSelects();
}
function switchTab(id) {
  const btn = [...document.querySelectorAll('.tab-item')].find(b => b.getAttribute('onclick').includes(id));
  goTab(id, btn);
}

// ── MODALS ─────────────────────────────────────────────
function openModal(id) {
  document.getElementById(id).classList.add('open');
  if (id === 'modal-ca') fillCaEpiSelect();
}
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
  clearModalForm(id);
}
function clearModalForm(id) {
  document.querySelectorAll(`#${id} input, #${id} select, #${id} textarea`).forEach(el => {
    if (el.type !== 'hidden') el.value = el.type === 'number' ? (el.id==='f-epi-min'?5:0) : '';
  });
  if (id === 'modal-epi') { document.getElementById('f-epi-id').value=''; document.getElementById('f-epi-emoji').value='🦺'; document.getElementById('modal-epi-title').textContent='🦺 Cadastrar EPI'; }
  if (id === 'modal-ca')  { document.getElementById('f-ca-id').value=''; document.getElementById('modal-ca-title').textContent='📄 Cadastrar C.A.'; }
  if (id === 'modal-tst') { document.getElementById('f-tst-id').value=''; document.getElementById('modal-tst-title').textContent='🛡️ Cadastrar Técnico de Segurança'; document.querySelectorAll('#tst-sites-check input').forEach(c=>c.checked=false); }
}
document.querySelectorAll('.modal-bg').forEach(bg => bg.addEventListener('click', e => { if(e.target===bg) closeModal(bg.id); }));

// ── TOAST ─────────────────────────────────────────────
let tTimer;
function showToast(msg, type='ok') {
  const t = document.getElementById('toast');
  const icons = {ok:'✅',err:'❌',warn:'⚠️'};
  t.className = `show t-${type==='ok'?'ok':type==='err'?'err':'warn'}`;
  document.getElementById('t-icon').textContent = icons[type]||'✅';
  document.getElementById('t-msg').textContent = msg;
  clearTimeout(tTimer);
  tTimer = setTimeout(() => t.classList.remove('show'), 3000);
}

// ── EPI CRUD ─────────────────────────────────────────
function salvarEPI() {
  const cod  = document.getElementById('f-epi-cod').value.trim();
  const nome = document.getElementById('f-epi-nome').value.trim();
  const cat  = document.getElementById('f-epi-cat').value;
  if (!cod||!nome||!cat) { showToast('Preencha os campos obrigatórios.','warn'); return; }
  const id = document.getElementById('f-epi-id').value;
  const epi = {
    id:         id || Date.now().toString(),
    codigo:     cod, nome, categoria: cat,
    descricao:  document.getElementById('f-epi-desc').value,
    ca:         document.getElementById('f-epi-ca').value,
    fabricante: document.getElementById('f-epi-fab').value,
    quantidade: parseInt(document.getElementById('f-epi-qty').value)||0,
    minimo:     parseInt(document.getElementById('f-epi-min').value)||5,
    local:      document.getElementById('f-epi-loc').value,
    emoji:      document.getElementById('f-epi-emoji').value||'🦺',
    site:       state.selectedSite?.id,
  };
  if (id) { const i=state.epis.findIndex(e=>e.id===id); if(i!==-1) state.epis[i]=epi; }
  else state.epis.push(epi);
  pushSheets('epis',id?'update':'insert',epi,id);
  save(); renderAll(); closeModal('modal-epi');
  showToast(`EPI "${nome}" salvo!`);
}

function editEPI(id) {
  const e = state.epis.find(x=>x.id===id); if(!e) return;
  document.getElementById('f-epi-id').value    = e.id;
  document.getElementById('f-epi-cod').value   = e.codigo;
  document.getElementById('f-epi-nome').value  = e.nome;
  document.getElementById('f-epi-cat').value   = e.categoria;
  document.getElementById('f-epi-desc').value  = e.descricao||'';
  document.getElementById('f-epi-ca').value    = e.ca||'';
  document.getElementById('f-epi-fab').value   = e.fabricante||'';
  document.getElementById('f-epi-qty').value   = e.quantidade;
  document.getElementById('f-epi-min').value   = e.minimo;
  document.getElementById('f-epi-loc').value   = e.local||'';
  document.getElementById('f-epi-emoji').value = e.emoji||'🦺';
  document.getElementById('modal-epi-title').textContent = '✎ Editar EPI';
  openModal('modal-epi');
}

function delEPI(id) {
  if (!confirm('Excluir este EPI?')) return;
  state.epis = state.epis.filter(e=>e.id!==id);
  pushSheets('epis','delete',null,id);
  save(); renderAll();
  showToast('EPI excluído.','warn');
}

// ── CA CRUD ──────────────────────────────────────────
function fillCaEpiSelect(sel='') {
  const s = document.getElementById('f-ca-epi');
  s.innerHTML = '<option value="">— nenhum —</option>';
  state.epis.forEach(e => {
    const o = document.createElement('option');
    o.value=e.id; o.textContent=`${e.codigo} — ${e.nome}`;
    if(e.id===sel) o.selected=true;
    s.appendChild(o);
  });
}

function salvarCA() {
  const num = document.getElementById('f-ca-num').value.trim();
  const fab = document.getElementById('f-ca-fab').value.trim();
  const val = document.getElementById('f-ca-val').value;
  if (!num||!fab||!val) { showToast('Preencha os campos obrigatórios.','warn'); return; }
  const id = document.getElementById('f-ca-id').value;
  const ca = {
    id: id||Date.now().toString(),
    numero:num, fabricante:fab, validade:val,
    epi: document.getElementById('f-ca-epi').value,
    cnpj: document.getElementById('f-ca-cnpj').value,
    emissao: document.getElementById('f-ca-emis').value,
    tipo: document.getElementById('f-ca-tipo').value,
    obs: document.getElementById('f-ca-obs').value,
  };
  if (id) { const i=state.cas.findIndex(c=>c.id===id); if(i!==-1) state.cas[i]=ca; }
  else state.cas.push(ca);
  pushSheets('cas',id?'update':'insert',ca,id);
  save(); renderAll(); closeModal('modal-ca');
  showToast(`C.A. ${num} salvo!`);
}

function editCA(id) {
  const c = state.cas.find(x=>x.id===id); if(!c) return;
  document.getElementById('f-ca-id').value    = c.id;
  document.getElementById('f-ca-num').value   = c.numero;
  document.getElementById('f-ca-fab').value   = c.fabricante;
  document.getElementById('f-ca-val').value   = c.validade;
  document.getElementById('f-ca-cnpj').value  = c.cnpj||'';
  document.getElementById('f-ca-emis').value  = c.emissao||'';
  document.getElementById('f-ca-tipo').value  = c.tipo||'';
  document.getElementById('f-ca-obs').value   = c.obs||'';
  fillCaEpiSelect(c.epi);
  document.getElementById('modal-ca-title').textContent='✎ Editar C.A.';
  openModal('modal-ca');
}

function delCA(id) {
  if (!confirm('Excluir este C.A.?')) return;
  state.cas = state.cas.filter(c=>c.id!==id);
  pushSheets('cas','delete',null,id);
  save(); renderAll();
  showToast('C.A. excluído.','warn');
