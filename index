function sugerirEPIs(funcao) {
  const box   = document.getElementById('epi-sugestao-box');
  const lista = document.getElementById('epi-sugestao-lista');
  if (!funcao || !FUNCAO_EPIS[funcao]) { box.classList.remove('show'); return; }
  const sugeridos = FUNCAO_EPIS[funcao];
  lista.innerHTML = sugeridos.map(nome => {
    // tenta achar no estoque
    const epi = state.epis.find(e => e.nome.toLowerCase().includes(nome.toLowerCase()));
    const qtd = epi ? ` — ${epi.quantidade} un.` : ' — não cadastrado';
    const cor = epi && epi.quantidade > 0 ? '#1eaa57' : '#aaa';
    return `<div class="epi-sug-item">
      <span style="font-size:16px;">${epi?.emoji||'🦺'}</span>
      <span style="flex:1;">${nome}</span>
      <span style="font-size:11px;font-weight:700;color:${cor};">${qtd}</span>
      ${epi ? `<button onclick="document.getElementById('mv-s-epi').value='${epi.id}'" style="background:var(--red-pale);border:none;border-radius:6px;padding:3px 8px;font-size:11px;font-weight:700;color:var(--red);cursor:pointer;">Selecionar</button>` : ''}
    </div>`;
  }).join('');
  box.classList.add('show');
}

// ── MOVIMENTAÇÃO ─────────────────────────────────────
function populateMoveSelects() {
  ['mv-s-epi','mv-e-epi'].forEach(sid => {
    const sel = document.getElementById(sid); if(!sel) return;
    const cur = sel.value;
    sel.innerHTML = '<option value="">Selecione o EPI</option>';
    state.epis.forEach(e => {
      const o = document.createElement('option');
      o.value=e.id; o.textContent=`${e.emoji||'🦺'} ${e.codigo} — ${e.nome} (${e.quantidade} un.)`;
      if(e.id===cur) o.selected=true;
      sel.appendChild(o);
    });
  });
}

function registrar(tipo) {
  if (tipo === 'saida') {
    const epiId = document.getElementById('mv-s-epi').value;
    const colab = document.getElementById('mv-s-colab').value.trim();
    const qty   = parseInt(document.getElementById('mv-s-qty').value)||0;
    if (!epiId||!colab||qty<1) { showToast('Preencha EPI, colaborador e quantidade.','warn'); return; }
    const epi = state.epis.find(e=>e.id===epiId);
    if (!epi) return;
    if (epi.quantidade < qty) { showToast(`Estoque insuficiente! Disponível: ${epi.quantidade}`,'err'); return; }
    epi.quantidade -= qty;
    const mov = {
      id: Date.now().toString(), tipo:'saida',
      epiId, epiNome:epi.nome, epiCod:epi.codigo,
      quantidade:qty,
      colaborador: colab,
      matricula: document.getElementById('mv-s-mat').value,
      setor: document.getElementById('mv-s-funcao').value,
      obs: document.getElementById('mv-s-obs').value,
      tecnica: state.loggedUser?.nome,
      site: state.selectedSite?.nome,
      data: new Date().toLocaleString('pt-BR'),
    };
    state.hist.unshift(mov);
    pushSheets('hist','insert',mov);
    pushSheets('epis','update',epi,epiId);
    ['mv-s-epi','mv-s-colab','mv-s-mat','mv-s-funcao','mv-s-obs'].forEach(id => document.getElementById(id).value='');
    document.getElementById('epi-sugestao-box').classList.remove('show');
    document.getElementById('mv-s-qty').value=1;
    showToast(`Saída: ${qty}x ${epi.nome} → ${colab}`);
  } else {
    const epiId = document.getElementById('mv-e-epi').value;
    const qty   = parseInt(document.getElementById('mv-e-qty').value)||0;
    if (!epiId||qty<1) { showToast('Selecione o EPI e informe a quantidade.','warn'); return; }
    const epi = state.epis.find(e=>e.id===epiId); if(!epi) return;
    epi.quantidade += qty;
    const mov = {
      id: Date.now().toString(), tipo:'entrada',
      epiId, epiNome:epi.nome, epiCod:epi.codigo,
      quantidade:qty,
      colaborador: document.getElementById('mv-e-forn').value,
      nf: document.getElementById('mv-e-nf').value,
      validade: document.getElementById('mv-e-val').value,
      obs: document.getElementById('mv-e-obs').value,
      tecnica: state.loggedUser?.nome,
      site: state.selectedSite?.nome,
      data: new Date().toLocaleString('pt-BR'),
    };
    state.hist.unshift(mov);
    pushSheets('hist','insert',mov);
    pushSheets('epis','update',epi,epiId);
    ['mv-e-epi','mv-e-forn','mv-e-nf','mv-e-val','mv-e-obs'].forEach(id => document.getElementById(id).value='');
    document.getElementById('mv-e-qty').value=1;
    showToast(`Entrada: ${qty}x ${epi.nome}`);
  }
  save(); renderAll(); populateMoveSelects();
}

// ── STATUS ───────────────────────────────────────────
function sts(e) {
  if (e.quantidade===0) return 'crit';
  if (e.minimo>0 && e.quantidade<e.minimo) return 'warn';
  return 'ok';
}

// ── RENDER ───────────────────────────────────────────
function renderAll() {
  renderDashboard();
  renderEpiTable();
  renderCATable();
  renderHistTable();
  renderTSTTable();
  renderLogTable();
}

function renderDashboard() {
  const total = state.epis.length;
  const ok    = state.epis.filter(e=>sts(e)==='ok').length;
  const warn  = state.epis.filter(e=>sts(e)==='warn').length;
  const crit  = state.epis.filter(e=>sts(e)==='crit').length;
  document.getElementById('s-total').textContent = total;
  document.getElementById('s-ok').textContent    = ok;
  document.getElementById('s-warn').textContent  = warn;
  document.getElementById('s-crit').textContent  = crit;

  const cont = document.getElementById('dash-cards');
  if (!total) {
    cont.innerHTML = `<div class="empty" style="grid-column:1/-1"><div class="ei">🦺</div><p>Nenhum EPI cadastrado.</p></div>`;
    return;
  }
  cont.innerHTML = state.epis.map(e => {
    const s = sts(e);
    const max = Math.max(e.minimo*2, e.quantidade, 1);
    const pct = Math.min(e.quantidade/max*100,100);
    return `<div class="epi-mini" onclick="editEPI('${e.id}')">
      <div class="epi-mini-top">
        <div>
          <div class="epi-mini-name">${e.nome}</div>
          <div class="epi-mini-code">${e.codigo}</div>
        </div>
        <span class="epi-emoji-big">${e.emoji||'🦺'}</span>
      </div>
      <div class="epi-mini-qty ${s}">${e.quantidade}</div>
      <div style="font-size:11px;color:var(--gray-500);margin-top:2px;">unidades</div>
      <div class="qty-track"><div class="qty-fill qf-${s}" style="width:${pct}%"></div></div>
      <div style="margin-top:8px;">
        <span class="badge-s bs-${s}">${s==='ok'?'OK':s==='warn'?'Atenção':'Crítico'}</span>
      </div>
    </div>`;
  }).join('');
}

